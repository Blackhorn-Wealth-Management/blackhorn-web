# ─── Sanity CMS ──────────────────────────────────────────────────────────────
# Get these from: https://sanity.io/manage → your project → Settings → API
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_TOKEN=

# ─── Revalidation Webhook ─────────────────────────────────────────────────────
# Must match the secret configured in Sanity → Manage → API → Webhooks
SANITY_REVALIDATE_SECRET=

# ─── Email (Resend) ───────────────────────────────────────────────────────────
# Get from: https://resend.com → API Keys
RESEND_API_KEY=

# ─── Site URL ─────────────────────────────────────────────────────────────────
# Used for sitemap, Open Graph tags, and JSON-LD structured data
NEXT_PUBLIC_SITE_URL=https://www.blackhorngrp.com
